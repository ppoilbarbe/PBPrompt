    <file alias="save_as.svg">icons/save_as.svg</file>
    <file alias="close.svg">icons/close.svg</file>
    <file alias="quit.svg">icons/quit.svg</file>
    <file alias="delete.svg">icons/delete.svg</file>
    <file alias="options.svg">icons/options.svg</file>
    <file alias="about.svg">icons/about.svg</file>
    <file alias="translate_right.svg">icons/translate_right.svg</file>
    <file alias="translate_left.svg">icons/translate_left.svg</file>
    <file alias="new_prompt.svg">icons/new_prompt.svg</file>
    <file alias="duplicate.svg">icons/duplicate.svg</file>
