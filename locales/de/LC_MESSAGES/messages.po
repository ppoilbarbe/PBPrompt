# Settings dialog – image viewer
#: src/pbprompt/gui/settings_dialog.py
msgid "Image viewer max zoom (×):"
msgstr "Max. Zoom der Bildanzeige (×):"

#: src/pbprompt/gui/settings_dialog.py
msgid "Maximum magnification in 'Fit' mode when the image is smaller\nthan the viewer window.\n1× to 16× (default: 4×)."
msgstr "Maximale Vergrößerung im Modus 'Anpassen', wenn das Bild\nkleiner als das Anzeigefenster ist.\n1× bis 16× (Standard: 4×)."

msgid "Zoom step (%):"
msgstr "Zoomschritt (%):"

msgid "Percentage added or removed when clicking + or −,\nor scrolling the mouse wheel in the image viewer.\n1% to 50% (default: 10%)."
msgstr "Prozentsatz, der beim Klicken auf + oder −\nbzw. beim Scrollen des Mausrads in der Bildanzeige hinzugefügt oder entfernt wird.\n1 % bis 50 % (Standard: 10 %)."

msgid "Keep original dimensions"
msgstr "Originale Abmessungen beibehalten"

msgid "When checked, images are stored as-is regardless of their size.\nWhen unchecked, images larger than the limits below are resized\nproportionally before being stored in the database."
msgstr "Wenn aktiviert, werden Bilder unabhängig von ihrer Größe unverändert gespeichert.\nWenn deaktiviert, werden Bilder, die die unten angegebenen Grenzen überschreiten,\nproportional skaliert, bevor sie in der Datenbank gespeichert werden."

msgid "Max width (px):"
msgstr "Max. Breite (px):"

msgid "Maximum width (in pixels) for images stored in the database.\nImages wider than this value are resized proportionally."
msgstr "Maximale Breite (in Pixeln) der in der Datenbank gespeicherten Bilder.\nBreitere Bilder werden proportional skaliert."

msgid "Max height (px):"
msgstr "Max. Höhe (px):"

msgid "Maximum height (in pixels) for images stored in the database.\nImages taller than this value are resized proportionally."
msgstr "Maximale Höhe (in Pixeln) der in der Datenbank gespeicherten Bilder.\nHöhere Bilder werden proportional skaliert."

msgid "Copy image"
msgstr "Bild kopieren"

msgid "Save image to file…"
msgstr "Bild in Datei speichern…"

msgid "Save Image"
msgstr "Bild speichern"

msgid "JPEG image (*.jpg *.jpeg)"
msgstr "JPEG-Bild (*.jpg *.jpeg)"

msgid "PNG image (*.png)"
msgstr "PNG-Bild (*.png)"

