# Settings dialog
msgid "Settings"
msgstr "Configuración"

msgid "Language"
msgstr "Idioma"

msgid "Display language:"
msgstr "Idioma de visualización:"

msgid ""
"Language used for the user interface.\n"
"'System default' uses the operating system locale."
msgstr ""
"Idioma utilizado en la interfaz de usuario.\n"
"'Sistema predeterminado' usa la configuración regional del sistema "
"operativo."

msgid "Translation language:"
msgstr "Idioma de traducción:"

msgid ""
"Language of the 'Local language' column.\n"
"Used as the source or target when translating prompts.\n"
"'System default' uses the operating system locale."
msgstr ""
"Idioma de la columna 'Idioma local'.\n"
"Se usa como origen o destino al traducir prompts.\n"
"'Sistema predeterminado' usa la configuración regional del sistema "
"operativo."

msgid "Translation service"
msgstr "Servicio de traducción"

msgid "Service:"
msgstr "Servicio:"

msgid ""
"Translation service used to fill the 'Local language' column\n"
"automatically when clicking the Translate button."
msgstr ""
"Servicio de traducción usado para completar la columna 'Idioma local'\n"
"automáticamente al hacer clic en el botón Traducir."

msgid "API key:"
msgstr "Clave API:"

msgid ""
"API key required by DeepL, Microsoft Translator, Yandex,\n"
"QCRI and LibreTranslate.\n"
"Leave blank for services that do not require one\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."
msgstr ""
"Clave API requerida por DeepL, Microsoft Translator, Yandex,\n"
"QCRI y LibreTranslate.\n"
"Dejar en blanco para servicios que no la necesitan\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."

msgid "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"
msgstr "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"

msgid "App ID:"
msgstr "ID de aplicación:"

msgid ""
"Application identifier required by some services:\n"
"• Baidu: appid\n"
"• Papago: client_id"
msgstr ""
"Identificador de aplicación requerido por algunos servicios:\n"
"• Baidu: appid\n"
"• Papago: client_id"

msgid "Baidu (appid) · Papago (client_id)"
msgstr "Baidu (appid) · Papago (client_id)"

msgid "App secret:"
msgstr "Secreto de aplicación:"

msgid ""
"Application secret required by some services:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"
msgstr ""
"Secreto de aplicación requerido por algunos servicios:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"

msgid "Baidu (appkey) · Papago (secret_key)"
msgstr "Baidu (appkey) · Papago (secret_key)"

msgid "Logging"
msgstr "Registro"

msgid "Log level:"
msgstr "Nivel de registro:"

msgid ""
"Verbosity of the application log.\n"
"DEBUG shows all messages; ERROR shows only critical failures.\n"
"Effective after restarting the application."
msgstr ""
"Nivel de detalle del registro de la aplicación.\n"
"DEBUG muestra todos los mensajes; ERROR muestra solo los fallos críticos."
"\n"
"Efectivo tras reiniciar la aplicación."

msgid "Files"
msgstr "Archivos"

msgid "Maximum recent files:"
msgstr "Máximo de archivos recientes:"

msgid "Maximum number of recently opened files shown in the File menu."
msgstr ""
"Número máximo de archivos abiertos recientemente mostrados en el menú "
"Archivo."

# Settings dialog – Images group
msgid "Images"
msgstr "Imágenes"

msgid "Thumbnail width (px):"
msgstr "Anchura de miniatura (px):"

msgid ""
"Maximum width (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Ancho máximo (en píxeles) de la miniatura almacenada en la base de datos."
"\n"
"Valores mayores mejoran la calidad pero aumentan el tamaño de la base de "
"datos."

msgid "Thumbnail height (px):"
msgstr "Altura de miniatura (px):"

msgid ""
"Maximum height (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Alto máximo (en píxeles) de la miniatura almacenada en la base de datos.\n"
"Valores mayores mejoran la calidad pero aumentan el tamaño de la base de "
"datos."

# Settings dialog – image viewer
msgid "Image viewer max zoom (×):"
msgstr "Zoom máx. del visor (×):"

msgid ""
"Maximum magnification in 'Fit' mode when the image is smaller\n"
"than the viewer window.\n"
"1× to 16× (default: 4×)."
msgstr ""
"Ampliación máxima en modo 'Ajustar' cuando la imagen\n"
"es más pequeña que la ventana del visor.\n"
"De 1× a 16× (predeterminado: 4×)."

msgid "Zoom step (%):"
msgstr "Paso de zoom (%):"

msgid ""
"Percentage added or removed when clicking + or −,\n"
"or scrolling the mouse wheel in the image viewer.\n"
"1% to 50% (default: 10%)."
msgstr ""
"Porcentaje añadido o quitado al hacer clic en + o −,\n"
"o al desplazar la rueda del ratón en el visor.\n"
"De 1% a 50% (predeterminado: 10%)."

msgid "Keep original dimensions"
msgstr "Conservar dimensiones originales"

msgid ""
"When checked, images are stored as-is regardless of their size.\n"
"When unchecked, images larger than the limits below are resized\n"
"proportionally before being stored in the database."
msgstr ""
"Si está marcado, las imágenes se almacenan tal cual, independientemente "
"de su tamaño.\n"
"Si no está marcado, las imágenes que superen los límites siguientes se "
"redimensionan\n"
"proporcionalmente antes de almacenarse en la base de datos."

msgid "Max width (px):"
msgstr "Ancho máximo (px):"

msgid ""
"Maximum width (in pixels) for images stored in the database.\n"
"Images wider than this value are resized proportionally."
msgstr ""
"Ancho máximo (en píxeles) de las imágenes almacenadas en la base de "
"datos.\n"
"Las imágenes más anchas se redimensionan proporcionalmente."

msgid "Max height (px):"
msgstr "Alto máximo (px):"

msgid ""
"Maximum height (in pixels) for images stored in the database.\n"
"Images taller than this value are resized proportionally."
msgstr ""
"Altura máxima (en píxeles) de las imágenes almacenadas en la base de "
"datos.\n"
"Las imágenes más altas se redimensionan proporcionalmente."

