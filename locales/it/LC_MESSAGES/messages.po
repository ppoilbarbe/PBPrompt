# Settings dialog
msgid "Settings"
msgstr "Impostazioni"

msgid "Language"
msgstr "Lingua"

msgid "Display language:"
msgstr "Lingua di visualizzazione:"

msgid ""
"Language used for the user interface.\n"
"'System default' uses the operating system locale."
msgstr ""
"Lingua utilizzata per l'interfaccia utente.\n"
"'Sistema predefinito' usa la lingua del sistema operativo."

msgid "Translation language:"
msgstr "Lingua di traduzione:"

msgid ""
"Language of the 'Local language' column.\n"
"Used as the source or target when translating prompts.\n"
"'System default' uses the operating system locale."
msgstr ""
"Lingua della colonna 'Lingua locale'.\n"
"Usata come sorgente o destinazione nella traduzione dei prompt.\n"
"'Sistema predefinito' usa la lingua del sistema operativo."

msgid "Translation service"
msgstr "Servizio di traduzione"

msgid "Service:"
msgstr "Servizio:"

msgid ""
"Translation service used to fill the 'Local language' column\n"
"automatically when clicking the Translate button."
msgstr ""
"Servizio di traduzione usato per compilare la colonna 'Lingua locale'\n"
"automaticamente cliccando il pulsante Traduci."

msgid "API key:"
msgstr "Chiave API:"

msgid ""
"API key required by DeepL, Microsoft Translator, Yandex,\n"
"QCRI and LibreTranslate.\n"
"Leave blank for services that do not require one\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."
msgstr ""
"Chiave API richiesta da DeepL, Microsoft Translator, Yandex,\n"
"QCRI e LibreTranslate.\n"
"Lasciare vuoto per i servizi che non la richiedono\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."

msgid "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"
msgstr "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"

msgid "App ID:"
msgstr "ID applicazione:"

msgid ""
"Application identifier required by some services:\n"
"• Baidu: appid\n"
"• Papago: client_id"
msgstr ""
"Identificatore applicazione richiesto da alcuni servizi:\n"
"• Baidu: appid\n"
"• Papago: client_id"

msgid "Baidu (appid) · Papago (client_id)"
msgstr "Baidu (appid) · Papago (client_id)"

msgid "App secret:"
msgstr "Segreto applicazione:"

msgid ""
"Application secret required by some services:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"
msgstr ""
"Segreto applicazione richiesto da alcuni servizi:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"

msgid "Baidu (appkey) · Papago (secret_key)"
msgstr "Baidu (appkey) · Papago (secret_key)"

msgid "Logging"
msgstr "Registro eventi"

msgid "Log level:"
msgstr "Livello di log:"

msgid ""
"Verbosity of the application log.\n"
"DEBUG shows all messages; ERROR shows only critical failures.\n"
"Effective after restarting the application."
msgstr ""
"Livello di dettaglio del registro dell'applicazione.\n"
"DEBUG mostra tutti i messaggi; ERROR mostra solo gli errori critici.\n"
"Effettivo dopo il riavvio dell'applicazione."

msgid "Files"
msgstr "File"

msgid "Maximum recent files:"
msgstr "Numero massimo di file recenti:"

msgid "Maximum number of recently opened files shown in the File menu."
msgstr "Numero massimo di file aperti di recente mostrati nel menu File."

# Settings dialog – Images group
msgid "Images"
msgstr "Immagini"

msgid "Thumbnail width (px):"
msgstr "Larghezza miniatura (px):"

msgid ""
"Maximum width (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Larghezza massima (in pixel) della miniatura memorizzata nel database.\n"
"Valori più grandi migliorano la qualità ma aumentano le dimensioni del "
"database."

msgid "Thumbnail height (px):"
msgstr "Altezza miniatura (px):"

msgid ""
"Maximum height (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Altezza massima (in pixel) della miniatura memorizzata nel database.\n"
"Valori più grandi migliorano la qualità ma aumentano le dimensioni del "
"database."

# Settings dialog – image viewer
msgid "Image viewer max zoom (×):"
msgstr "Zoom max del visualizzatore (×):"

msgid ""
"Maximum magnification in 'Fit' mode when the image is smaller\n"
"than the viewer window.\n"
"1× to 16× (default: 4×)."
msgstr ""
"Ingrandimento massimo in modalità 'Adatta' quando l'immagine\n"
"è più piccola della finestra.\n"
"Da 1× a 16× (predefinito: 4×)."

msgid "Zoom step (%):"
msgstr "Passo di zoom (%):"

msgid ""
"Percentage added or removed when clicking + or −,\n"
"or scrolling the mouse wheel in the image viewer.\n"
"1% to 50% (default: 10%)."
msgstr ""
"Percentuale aggiunta o sottratta facendo clic su + o −,\n"
"o scorrendo la rotella del mouse nel visualizzatore.\n"
"Da 1% a 50% (predefinito: 10%)."

msgid "Keep original dimensions"
msgstr "Mantieni dimensioni originali"

msgid ""
"When checked, images are stored as-is regardless of their size.\n"
"When unchecked, images larger than the limits below are resized\n"
"proportionally before being stored in the database."
msgstr ""
"Se selezionato, le immagini vengono archiviate così come sono, "
"indipendentemente dalle dimensioni.\n"
"Se deselezionato, le immagini che superano i limiti seguenti vengono "
"ridimensionate\n"
"proportionalmente prima di essere archiviate nel database."

msgid "Max width (px):"
msgstr "Larghezza massima (px):"

msgid ""
"Maximum width (in pixels) for images stored in the database.\n"
"Images wider than this value are resized proportionally."
msgstr ""
"Larghezza massima (in pixel) delle immagini archiviate nel database.\n"
"Le immagini più larghe vengono ridimensionate proporzionalmente."

msgid "Max height (px):"
msgstr "Altezza massima (px):"

msgid ""
"Maximum height (in pixels) for images stored in the database.\n"
"Images taller than this value are resized proportionally."
msgstr ""
"Altezza massima (in pixel) delle immagini archiviate nel database.\n"
"Le immagini più alte vengono ridimensionate proporzionalmente."

# Settings dialog – language selector
msgid "System default"
msgstr "Predefinito di sistema"
