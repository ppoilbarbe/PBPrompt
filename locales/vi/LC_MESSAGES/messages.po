# Settings dialog
#: src/pbprompt/gui/settings_dialog.py:148
msgid "Settings"
msgstr "Cài đặt"

#: src/pbprompt/gui/settings_dialog.py:151
msgid "Language"
msgstr "Ngôn ngữ"

#: src/pbprompt/gui/settings_dialog.py:152
msgid "Display language:"
msgstr "Ngôn ngữ hiển thị:"

#: src/pbprompt/gui/settings_dialog.py:155
msgid ""
"Language used for the user interface.\n"
"'System default' uses the operating system locale."
msgstr ""
"Ngôn ngữ sử dụng cho giao diện người dùng.\n"
"'Mặc định hệ thống' sử dụng ngôn ngữ của hệ điều hành."

#: src/pbprompt/gui/settings_dialog.py:159
msgid "Translation language:"
msgstr "Ngôn ngữ dịch:"

#: src/pbprompt/gui/settings_dialog.py:162
msgid ""
"Language of the 'Local language' column.\n"
"Used as the source or target when translating prompts.\n"
"'System default' uses the operating system locale."
msgstr ""
"Ngôn ngữ của cột 'Ngôn ngữ địa phương'.\n"
"Dùng làm nguồn hoặc đích khi dịch các prompt.\n"
"'Mặc định hệ thống' sử dụng ngôn ngữ của hệ điều hành."

#: src/pbprompt/gui/settings_dialog.py:169
msgid "Translation service"
msgstr "Dịch vụ dịch thuật"

#: src/pbprompt/gui/settings_dialog.py:170
msgid "Service:"
msgstr "Dịch vụ:"

#: src/pbprompt/gui/settings_dialog.py:173
msgid ""
"Translation service used to fill the 'Local language' column\n"
"automatically when clicking the Translate button."
msgstr ""
"Dịch vụ dịch thuật dùng để điền cột 'Ngôn ngữ địa phương'\n"
"tự động khi nhấp vào nút Dịch."

#: src/pbprompt/gui/settings_dialog.py:177
msgid "API key:"
msgstr "Khóa API:"

#: src/pbprompt/gui/settings_dialog.py:180
msgid ""
"API key required by DeepL, Microsoft Translator, Yandex,\n"
"QCRI and LibreTranslate.\n"
"Leave blank for services that do not require one\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."
msgstr ""
"Khóa API yêu cầu bởi DeepL, Microsoft Translator, Yandex,\n"
"QCRI và LibreTranslate.\n"
"Để trống cho các dịch vụ không yêu cầu\n"
"(Google, MyMemory, PONS, Linguee, Reverso…)."

#: src/pbprompt/gui/settings_dialog.py:187
msgid "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"
msgstr "DeepL, Microsoft, Yandex, QCRI, LibreTranslate"

#: src/pbprompt/gui/settings_dialog.py:189
msgid "App ID:"
msgstr "ID ứng dụng:"

#: src/pbprompt/gui/settings_dialog.py:192
msgid ""
"Application identifier required by some services:\n"
"• Baidu: appid\n"
"• Papago: client_id"
msgstr ""
"Mã định danh ứng dụng yêu cầu bởi một số dịch vụ:\n"
"• Baidu: appid\n"
"• Papago: client_id"

#: src/pbprompt/gui/settings_dialog.py:197
msgid "Baidu (appid) · Papago (client_id)"
msgstr "Baidu (appid) · Papago (client_id)"

#: src/pbprompt/gui/settings_dialog.py:198
msgid "App secret:"
msgstr "Bí mật ứng dụng:"

#: src/pbprompt/gui/settings_dialog.py:201
msgid ""
"Application secret required by some services:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"
msgstr ""
"Bí mật ứng dụng yêu cầu bởi một số dịch vụ:\n"
"• Baidu: appkey\n"
"• Papago: secret_key"

#: src/pbprompt/gui/settings_dialog.py:207
msgid "Baidu (appkey) · Papago (secret_key)"
msgstr "Baidu (appkey) · Papago (secret_key)"

#: src/pbprompt/gui/settings_dialog.py:211
msgid "Logging"
msgstr "Nhật ký"

#: src/pbprompt/gui/settings_dialog.py:212
msgid "Log level:"
msgstr "Cấp độ nhật ký:"

#: src/pbprompt/gui/settings_dialog.py:215
msgid ""
"Verbosity of the application log.\n"
"DEBUG shows all messages; ERROR shows only critical failures.\n"
"Effective after restarting the application."
msgstr ""
"Mức độ chi tiết của nhật ký ứng dụng.\n"
"DEBUG hiển thị tất cả thông báo; ERROR chỉ hiển thị lỗi nghiêm trọng.\n"
"Có hiệu lực sau khi khởi động lại ứng dụng."

#: src/pbprompt/gui/settings_dialog.py:222
msgid "Files"
msgstr "Tệp"

#: src/pbprompt/gui/settings_dialog.py:223
msgid "Maximum recent files:"
msgstr "Số tệp gần đây tối đa:"

#: src/pbprompt/gui/settings_dialog.py:225
msgid "Maximum number of recently opened files shown in the File menu."
msgstr "Số tối đa các tệp đã mở gần đây hiển thị trong menu Tệp."

# Settings dialog – Images group
#: src/pbprompt/gui/settings_dialog.py:229
msgid "Images"
msgstr "Hình ảnh"

#: src/pbprompt/gui/settings_dialog.py:230
msgid "Thumbnail width (px):"
msgstr "Chiều rộng hình thu nhỏ (px):"

#: src/pbprompt/gui/settings_dialog.py:233
msgid ""
"Maximum width (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Chiều rộng tối đa (tính bằng pixel) của hình thu nhỏ lưu trong cơ sở dữ liệu.\n"
"Giá trị lớn hơn cải thiện chất lượng nhưng tăng kích thước cơ sở dữ liệu."

#: src/pbprompt/gui/settings_dialog.py:237
msgid "Thumbnail height (px):"
msgstr "Chiều cao hình thu nhỏ (px):"

#: src/pbprompt/gui/settings_dialog.py:240
msgid ""
"Maximum height (in pixels) of the thumbnail stored in the database.\n"
"Larger values improve quality but increase database size."
msgstr ""
"Chiều cao tối đa (tính bằng pixel) của hình thu nhỏ lưu trong cơ sở dữ liệu.\n"
"Giá trị lớn hơn cải thiện chất lượng nhưng tăng kích thước cơ sở dữ liệu."

